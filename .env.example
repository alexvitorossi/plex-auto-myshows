# Plex
PLEX_URL=http://192.168.1.10:32400
PLEX_TOKEN=changeme
# Username (Plex account) which events we should react to.
# Leave empty to react to all sessions.
PLEX_USERNAME=

# MyShows (OAuth2 password grant; client_id/secret default to apidoc/apidoc)
MYSHOWS_LOGIN=
MYSHOWS_PASSWORD=

# Runtime
LOG_LEVEL=INFO
DATA_DIR=/data
# IANA timezone for catch-up time math (defaults to Central European Time).
TZ=Europe/Belgrade
# If true, only log; do not call MyShows API or write watched items to cache.
DRY_RUN=true

# Progress (percent) at which an episode counts as watched in real time.
# Default 90; lower it (e.g. 85) if some releases roll credits early.
WATCHED_THRESHOLD_PERCENT=90

# Catch-up: process Plex.history() entries created while the service was down.
# Duplicates are skipped by the cache and will not be marked twice.
CATCHUP_ON_START=true
CATCHUP_INTERVAL_HOURS=24
CATCHUP_LOOKBACK_HOURS=24
